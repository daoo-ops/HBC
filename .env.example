DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database
# Use sqlite by default in local development
DB_ENGINE=sqlite
# For postgres, set DB_ENGINE=postgres and complete fields below
DB_NAME=hbc_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
